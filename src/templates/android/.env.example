# ─── Android Studio DevContainer 环境变量 ────────────────────────────────────
# 复制此文件为 .env，填写对应值后执行：
#   docker compose --env-file .env up -d

# ─── VNC 密码（必填）────────────────────────────────────────────────────────
VNC_PASSWORD=changeme

# ─── 设备 GID（在宿主机 Ubuntu 上执行以下命令获取）───────────────────────────
# KVM 加速（x86_64 Android 模拟器必须）
#   grep '^kvm:' /etc/group | cut -d: -f3
KVM_GID=

# DRI 渲染节点（NVIDIA Vulkan / OpenGL）
#   grep '^render:' /etc/group | cut -d: -f3
RENDER_GID=

# 视频设备
#   grep '^video:' /etc/group | cut -d: -f3
VIDEO_GID=
