{
  "editor.tabSize": 2,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "files.associations": {
    "devcontainer.prebuilt.json": "jsonc"
  },
  "chat.tools.terminal.autoApprove": {
    "set": true,
    "mkdir": true,
    "mv": true
  }
}
