{
  "name": "Ubuntu (Pre-built)",
  "image": "ghcr.io/alexwithdev/devcontainer-template/ubuntu:latest",
  "features": {},
  "remoteUser": "developer",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.shell.linux": "/bin/zsh"
      }
    }
  }
}
